# Copy this file to .env and fill in the values

# Port the server listens on (Railway sets this automatically)
PORT=3000

# API Key — any long random string, e.g. from https://www.uuidgenerator.net/
# All devices must send this in the X-API-Key header
# Leave blank to disable auth (not recommended for production)
API_KEY=your-secret-key-here

# Directory where the SQLite database file is stored
# Railway uses /data as a persistent volume — set this to /data on Railway
DATA_DIR=./data
